<?xml version="1.0" encoding="utf-8"?>

<!-- Material 3 Search Layout (Reverse/Bottom) with CoordinatorLayout and MaterialCardView -->
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/launchpad_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/launchpad_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom">

        <!-- Main Search Card - Glass Effect (Bottom-aligned) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/search_card_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/glass_card"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:id="@+id/search_card_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/large_spacing"
                android:fitsSystemWindows="true">

                <!-- Results RecyclerView (above search bar in reverse layout) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/results_view"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/search_result_holder_height"
                    android:paddingTop="@dimen/result_item_alternate_margin_top"
                    android:orientation="vertical"
                    android:clipToPadding="false"
                    android:requiresFadingEdge="vertical"
                    android:fadingEdgeLength="16dp"
                    android:overScrollMode="never"
                    app:reverseLayout="true" />

                <!-- Search Bar - Floating Pill Shape -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/search_bar_card"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/search_bar_height"
                    android:layout_margin="@dimen/large_spacing"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="@color/glass_surface"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:stateListAnimator="@animator/search_bar_elevation"
                    android:fitsSystemWindows="true">

                    <EditText
                        android:id="@+id/search_input"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="@dimen/search_bar_input_padding"
                        android:layout_gravity="center"
                        android:drawableStart="@drawable/baseline_search_24"
                        android:drawablePadding="12dp"
                        android:background="@android:color/transparent"
                        android:hint="@string/search_bar_input_text"
                        android:singleLine="true"
                        android:textAlignment="viewStart"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:inputType="text"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:imeOptions="actionSearch" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:orientation="horizontal"
                    android:paddingBottom="@dimen/large_spacing">

                    <ImageButton
                        android:id="@+id/action_settings"
                        android:layout_width="@dimen/search_action_button_geometry"
                        android:layout_height="@dimen/search_action_button_geometry"
                        android:layout_margin="@dimen/default_spacing"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/baseline_settings_24"
                        android:contentDescription="@string/search_action_settings" />

                    <ImageButton
                        android:id="@+id/action_close"
                        android:layout_width="@dimen/search_action_button_geometry"
                        android:layout_height="@dimen/search_action_button_geometry"
                        android:layout_margin="@dimen/default_spacing"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/baseline_close_24"
                        android:contentDescription="@string/search_action_close" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>